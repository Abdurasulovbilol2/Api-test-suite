{
  "name": "api-test-suite",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test tests/auth tests/users tests/performance",
    "test:frontend": "playwright test tests/frontend",
    "test:pw": "playwright test --grep \"@pw\"",
    "test:axios": "playwright test --grep \"@axios\"",
    "test:auth": "playwright test tests/auth",
    "test:users": "playwright test tests/users",
    "test:performance": "playwright test tests/performance",
    "report:html": "playwright show-report",
    "report:allure": "allure generate ./allure-results --clean -o ./allure-report"
  },
  "keywords": [
    "playwright",
    "testing",
    "api",
    "automation",
    "e2e",
    "rest-api",
    "frontend",
    "performance",
    "ci-cd",
    "github-actions",
    "axios",
    "zod"
  ],
  "author": "Abdurasulov Bilol",
  "license": "MIT",
  "description": "Comprehensive testing framework for REST APIs and frontend UI with Playwright, Axios, and GitHub Actions CI/CD",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "dotenv": "^17.4.0",
    "zod": "^4.3.6"
  }
}
